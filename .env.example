# Copy to .env and fill in your values

# Optional — app works without this (job history disabled)
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/pii-redactor

# Frontend URL for CORS (set this on Vercel to your frontend domain)
FRONTEND_URL=https://your-app.vercel.app

# Backend port for local dev
PORT=4000
